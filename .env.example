# Database Configuration
DATABASE_URL="postgresql://postgres:password@localhost:5432/securegate"

# NextAuth Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="use-a-securely-generated-32-character-random-key"

# Transactional Email (SMTP / Nodemailer)
# Leave unset to run in console mock mode (links printed to terminal)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="SecureGate <noreply@yourdomain.com>"

# Brute-Force Rate Limiting (Upstash Redis)
UPSTASH_REDIS_REST_URL="https://your-upstash-redis-rest-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-redis-rest-token"
