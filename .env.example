# Database Configuration
DATABASE_URL="postgresql://postgres:password@localhost:5432/securegate"

# NextAuth Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="use-a-securely-generated-32-character-random-key"

# Transactional Email (Resend API)
RESEND_API_KEY="re_123456789"

# Brute-Force Rate Limiting (Upstash Redis)
UPSTASH_REDIS_REST_URL="https://your-upstash-redis-rest-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-redis-rest-token"
